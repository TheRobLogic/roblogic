      {
        "parameters": {
          "jsCode": "const fs = require('fs');\nconst FILE = '/peach-logs/booker-tasks.json';\nconst NINETY_DAYS_MS = 90 * 24 * 60 * 60 * 1000;\nconst now = Date.now();\nconst user = $input.first().json.headers['x-booker-user'] || 'unknown';\n\nlet data;\ntry {\n  data = JSON.parse(fs.readFileSync(FILE, 'utf8'));\n} catch (e) {\n  data = { tasks: [], history: [] };\n}\n\n// Prune done tasks older than 90 days\nconst cutoff = new Date(now - NINETY_DAYS_MS).toISOString();\ndata.tasks = data.tasks.filter(t =>\n  t.status === 'active' || (t.completed_at && t.completed_at > cutoff)\n);\n\n// Prune old history\ndata.history = data.history.filter(h => h.at > cutoff);\n\n// Write pruned data back\nfs.writeFileSync(FILE, JSON.stringify(data, null, 2));\n\nreturn [{ json: { tasks: data.tasks, history: data.history, user } }];"
        },
