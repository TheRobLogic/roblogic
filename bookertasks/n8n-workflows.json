      {
        "parameters": {
          "jsCode": "const fs = require('fs');\nconst FILE = '/peach-logs/booker-tasks.json';\nconst user = $input.first().json.headers['x-booker-user'] || 'unknown';\nconst body = $input.first().json.body;\n\nif (!body || !body.title) {\n  return [{ json: { success: false, error: 'Missing title' } }];\n}\n\nlet data;\ntry {\n  data = JSON.parse(fs.readFileSync(FILE, 'utf8'));\n} catch (e) {\n  data = { tasks: [], history: [] };\n}\n\nconst task = {\n  id: `t-${Date.now()}`,\n  title: body.title,\n  notes: body.notes || '',\n  context: body.context || '',\n  priority: body.priority || 'medium',\n  due: body.due || null,\n  status: 'active',\n  source: user === 'briefing' ? 'briefing' : 'manual',\n  created_at: new Date().toISOString(),\n  created_by: user,\n  completed_at: null,\n  completed_by: null,\n};\n\ndata.tasks.push(task);\ndata.history.push({\n  task_id: task.id,\n  action: 'created',\n  by: user,\n  at: task.created_at,\n  title: null,\n});\n\nfs.writeFileSync(FILE, JSON.stringify(data, null, 2));\nreturn [{ json: { success: true, task } }];"
