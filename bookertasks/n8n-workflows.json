        "id": "a4000004-0004-0004-0004-000000000002",
        "name": "Auth Check",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2,
        "position": [
          470,
          300
        ]
      },
      {
        "parameters": {
          "jsCode": "const fs = require('fs');\nconst FILE = '/peach-logs/booker-tasks.json';\nconst user = $input.first().json.headers['x-booker-user'] || 'unknown';\nconst body = $input.first().json.body;\n\nif (!body || !body.id) {\n  return [{ json: { success: false, error: 'Missing task id' } }];\n}\n\nlet data;\ntry {\n  data = JSON.parse(fs.readFileSync(FILE, 'utf8'));\n} catch (e) {\n  data = { tasks: [], history: [] };\n}\n\nconst idx = data.tasks.findIndex(t => t.id === body.id);\nif (idx === -1) {\n  return [{ json: { success: false, error: 'Task not found' } }];\n}\n\nconst task = data.tasks[idx];\nlet action = 'edited';\n\n// Update allowed fields\nif (body.title !== undefined) task.title = body.title;\nif (body.notes !== undefined) task.notes = body.notes;\nif (body.priority !== undefined) task.priority = body.priority;\nif (body.due !== undefined) task.due = body.due;\n\nif (body.status !== undefined) {\n  if (body.status === 'done' && task.status === 'active') {\n    task.status = 'done';\n    task.completed_at = new Date().toISOString();\n    task.completed_by = user;\n    action = 'completed';\n  } else if (body.status === 'active' && task.status === 'done') {\n    task.status = 'active';\n    task.completed_at = null;\n    task.completed_by = null;\n    action = 'unchecked';\n  }\n}\n\ndata.history.push({\n  task_id: task.id,\n  action,\n  by: user,\n  at: new Date().toISOString(),\n  title: null,\n});\n\nfs.writeFileSync(FILE, JSON.stringify(data, null, 2));\nreturn [{ json: { success: true, task } }];"
        },
