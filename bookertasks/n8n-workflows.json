      },
      {
        "parameters": {
          "jsCode": "const fs = require('fs');\nconst FILE = '/peach-logs/booker-tasks.json';\nconst user = $input.first().json.headers['x-booker-user'] || 'unknown';\nconst body = $input.first().json.body;\n\nif (!body || !Array.isArray(body.tasks) || body.tasks.length === 0) {\n  return [{ json: { success: false, error: 'Missing or empty tasks array' } }];\n}\n\nlet data;\ntry {\n  data = JSON.parse(fs.readFileSync(FILE, 'utf8'));\n} catch (e) {\n  data = { tasks: [], history: [] };\n}\n\nconst now = Date.now();\nconst added = [];\n\nfor (let i = 0; i < body.tasks.length; i++) {\n  const t = body.tasks[i];\n  if (!t.title) continue;\n\n  const task = {\n    id: `t-${now + i}`,\n    title: t.title,\n    notes: t.notes || '',\n    context: t.context || '',\n    priority: t.priority || 'medium',\n    due: t.due || null,\n    status: 'active',\n    source: user === 'briefing' ? 'briefing' : 'manual',\n    created_at: new Date().toISOString(),\n    created_by: user,\n    completed_at: null,\n    completed_by: null,\n  };\n\n  data.tasks.push(task);\n  data.history.push({\n    task_id: task.id,\n    action: 'created',\n    by: user,\n    at: task.created_at,\n    title: null,\n  });\n  added.push(task);\n}\n\nfs.writeFileSync(FILE, JSON.stringify(data, null, 2));\nreturn [{ json: { success: true, added: added.length, tasks: added } }];"
        },
